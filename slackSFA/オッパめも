import { z } from 'zod';
import { Request, Response, NextFunction } from 'express';

// ── スキーマ定義 ─────────────────────────────────────────

const LIFECYCLE_STAGES = ['prospect', 'active', 'customer', 'inactive', 'churned'] as const;

export const contactPatchSchema = z.object({
  last_name:       z.string().min(1).max(100).optional(),
  first_name:      z.string().max(100).nullable().optional(),
  email:           z.string().email().max(255).nullable().optional(),
  phone:           z.string().max(30).nullable().optional(),
  mobile:          z.string().max(30).nullable().optional(),
  title:           z.string().max(100).nullable().optional(),
  department:      z.string().max(100).nullable().optional(),
  lifecycle_stage: z.enum(LIFECYCLE_STAGES).optional(),
  company_name:    z.string().max(255).nullable().optional(),
  source:          z.string().max(100).nullable().optional(),
  website_url:     z.string().url().max(500).nullable().optional(),
  is_primary:      z.boolean().optional(),
}).strict();

export const tenantPatchSchema = z.object({
  nurturing_mode:   z.enum(['off', 'notify_only', 'draft']).optional(),
  sales_policy:     z.string().max(2000).nullable().optional(),
  slack_invite_url: z.string().url().max(500).nullable().optional(),
}).strict();

// ── バリデーションミドルウェアファクトリ ─────────────────

export function validate(schema: z.ZodTypeAny) {
  return (req: Request, res: Response, next: NextFunction): void => {
    const result = schema.safeParse(req.body);
    if (!result.success) {
      res.status(400).json({
        error: 'Validation failed',
        details: result.error.errors.map(e => ({
          field: e.path.join('.'),
          message: e.message,
        })),
      });
      return;
    }
    req.body = result.data;
    next();
  };
}
